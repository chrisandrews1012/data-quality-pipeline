    "first_name": "text",
    "age": "age",
    "gender": "categorical",
    "diagnosis": "categorical",
    "bmi": "numeric",
    "visit_date": "date",
    "notes": "text"
  },
  "must_repair": {
    "duplicate_rows": true,
    "columns": {
      "age": ["out_of_range"],
      "diagnosis": ["mixed_case"],
      "visit_date": ["date_format"]
    }
  },
  "must_flag_unresolved": ["notes"],
  "must_not_impute_mnar": true
}
